{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "es6",
    /**
     * @note Tests are never built. Vitest executes them as ESM,
     * so use bundler module semantics (they permit `import.meta`,
     * which "NodeNext" forbids in files it classifies as CommonJS).
     */
    "module": "preserve",
    "moduleResolution": "bundler",
    "types": ["node", "vitest/globals"],
  },
  "include": ["setup/vitest.ts", "**/*.test.ts"],
}

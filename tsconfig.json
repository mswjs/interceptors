{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    /**
     * @note This is the editor/type-checking project: it covers the
     * source, the tests, and the tooling configs, and never emits.
     * The build compiles through `tsconfig.src.json`/`tsconfig.browser.json`
     * via tsdown.
     */
    "module": "preserve",
    "moduleResolution": "bundler",
    "noEmit": true,
    "types": ["node", "vitest/globals"],
  },
  "include": [
    "./src/**/*.ts",
    "./test/**/*.ts",
    "./vitest.config.ts",
    "./vitest.setup.ts",
    "./tsdown.config.ts",
  ],
  "exclude": ["node_modules", "lib", "tmp"],
}

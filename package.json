{
  "type": "module",
  "name": "@mswjs/interceptors",
  "description": "Low-level network interception library for Node.js.",
  "version": "0.41.9",
  "main": "./lib/node/index.js",
  "types": "./lib/node/index.d.ts",
  "exports": {
    ".": {
      "browser": "./lib/browser/index.js",
      "default": "./lib/node/index.js"
    },
    "./net": {
      "browser": null,
      "default": "./lib/node/interceptors/net/index.js"
    },
    "./http": {
      "browser": null,
      "default": "./lib/node/interceptors/http/index.js"
    },
    "./ClientRequest": {
      "browser": null,
      "default": "./lib/node/interceptors/ClientRequest/index.js"
    },
    "./XMLHttpRequest": {
      "browser": "./lib/browser/interceptors/XMLHttpRequest/web.js",
      "default": "./lib/node/interceptors/XMLHttpRequest/node.js"
    },
    "./XMLHttpRequest/node": "./lib/node/interceptors/XMLHttpRequest/node.js",
    "./XMLHttpRequest/web": "./lib/browser/interceptors/XMLHttpRequest/web.js",
    "./fetch": {
      "browser": "./lib/browser/interceptors/fetch/web.js",
      "default": "./lib/node/interceptors/fetch/node.js"
    },
    "./fetch/node": "./lib/node/interceptors/fetch/node.js",
    "./fetch/web": "./lib/browser/interceptors/fetch/web.js",
    "./WebSocket": "./lib/browser/interceptors/WebSocket/index.js",
    "./RemoteHttpInterceptor": {
      "browser": null,
      "default": "./lib/node/remote-http-interceptor.js"
    },
    "./presets/node": {
      "browser": null,
      "default": "./lib/node/presets/node.js"
    },
    "./presets/browser": {
      "node": null,
      "browser": "./lib/browser/presets/browser.js"
    }
  },
  "imports": {
    "#/src/*": "./src/*",
    "#/test/*": "./test/*"
  },
  "author": "Artem Zakharchenko",
  "license": "MIT",
  "scripts": {
    "start": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "test:nock": "./test/third-party/nock.sh",
    "lint": "publint",
    "build": "tsdown",
    "prepare": "pnpm simple-git-hooks init",
    "release": "release publish"
  },
  "files": [
    "lib",
    "src"
  ],
  "repository": {
    "url": "https://github.com/mswjs/interceptors"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@open-draft/until": "^3.0.1",
    "@types/debug": "^4.1.13",
    "debug": "^4.4.3",
    "is-node-process": "^1.2.0",
    "outvariant": "^1.4.3",
    "rettime": "^0.11.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@epic-web/test-server": "^0.1.6",
    "@hono/node-server": "^1.19.14",
    "@ossjs/release": "^0.11.0",
    "@types/express": "^5.0.6",
    "@types/follow-redirects": "^1.14.1",
    "@types/node": "^22.13.9",
    "@types/node-fetch": "2.6.13",
    "@types/superagent": "^8.1.9",
    "@types/supertest": "^7.2.1",
    "@types/ws": "^8.18.1",
    "@vitest/browser-playwright": "^4.1.10",
    "axios": "^1.18.1",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "3.3.0",
    "engine.io-parser": "^5.2.1",
    "express": "^5.2.1",
    "follow-redirects": "^1.15.1",
    "got": "^15.1.0",
    "happy-dom": "^20.8.3",
    "hono": "^4.12.31",
    "https-proxy-agent": "^9.1.0",
    "jsdom": "^29.1.1",
    "node-fetch": "3.3.2",
    "playwright": "^1.61.1",
    "publint": "^0.3.18",
    "simple-git-hooks": "^2.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "socket.io-parser": "^4.2.6",
    "superagent": "^10.3.0",
    "supertest": "^7.2.2",
    "tsdown": "^0.22.12",
    "typescript": "^7.0.2",
    "undici": "^8.8.0",
    "vitest": "^4.1.10",
    "vitest-environment-miniflare": "^2.14.4",
    "web-encoding": "^1.1.5",
    "ws": "^8.21.0"
  },
  "resolutions": {
    "memfs": "^3.4.13"
  },
  "keywords": [
    "request",
    "intercept",
    "http",
    "https",
    "xmlhttprequest",
    "xhr",
    "fetch",
    "low-level",
    "mock",
    "spy",
    "testing"
  ],
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
